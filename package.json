{
  "name": "nest-admin",
  "version": "0.0.1",
  "description": "simple and efficient authority management system with separation of front and backends",
  "author": "buqiyuan",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "cross-env NODE_ENV=development nest start",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "pm2:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:test": "pm2 start ecosystem.config.js --env test",
    "migration:create": "npx typeorm-ts-node-commonjs migration:create ./src/migrations/create-table",
    "migration:generate": "node ./scripts/migration-generate.js",
    "migration:run": "npm run build&&npx typeorm-ts-node-commonjs migration:run -d ./src/config/data-source.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d ./src/config/data-source.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "cleanlog": "rimraf logs",
    "docker:rmi": "docker compose --env-file .env.production stop nest-admin-server && docker container rm nest-admin-server && docker rmi nest-admin-server",
    "docker:build:dev": "docker compose --env-file .env.development up --build",
    "docker:build": "docker compose --env-file .env.production up --build",
    "docker:up": "docker compose --env-file .env.production up -d --no-build",
    "docker:down": "docker compose --env-file .env.production down",
    "docker:logs": "docker compose --env-file .env.production logs -f",
    "prebuild": "rimraf dist",
    "prepare": "husky install"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "argon2": "^0.44.0",
    "bull": "^4.10.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "^0.15.1",
    "cron-parser": "4.9.0",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.29.3",
    "dotenv": "16.1.4",
    "fastify": "^5.8.5",
    "ioredis": "^5.2.4",
    "keyv": "^5.6.0",
    "lodash": "^4.17.21",
    "mysql2": "^3.22.3",
    "nanoid": "^3.3.4",
    "qiniu": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "4.6.2",
    "svg-captcha": "^1.4.0",
    "systeminformation": "^5.14.4",
    "typeorm": "^0.3.29",
    "ua-parser-js": "^1.0.32",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bull": "^4.10.0",
    "@types/jest": "^29.2.3",
    "@types/lodash": "^4.14.190",
    "@types/node": "^22.19.18",
    "@types/supertest": "^7.2.0",
    "@types/ua-parser-js": "^0.7.36",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.2",
    "jest": "^29.7.0",
    "lint-staged": "^13.0.4",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.4.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=22"
  }
}
